{
  "name": "@pleaseai/spring-docs",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "Pre-converted, version-pinned Spring documentation in Markdown — distributed as GitHub Release archives",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pleaseai/spring-docs.git"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "bun --bun x eslint --max-warnings 0",
    "lint:fix": "bun --bun x eslint --fix",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate-catalog": "bun run scripts/validate-catalog.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@pleaseai/eslint-config": "^0.0.1",
    "@types/bun": "^1.1.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^15.5.2",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "bun --bun x eslint --fix"
    ]
  }
}
